{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "fs:allow-read",
      "allow": [
        { "path": "$HOME/.openclaw" },
        { "path": "$HOME/.openclaw/**" },
        { "path": "$HOME/.openclaw-autoclaw" },
        { "path": "$HOME/.openclaw-autoclaw/**" },
        { "path": "$HOME/.hermes" },
        { "path": "$HOME/.hermes/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/.openclaw" },
        { "path": "$HOME/.openclaw/**" },
        { "path": "$HOME/.openclaw-autoclaw" },
        { "path": "$HOME/.openclaw-autoclaw/**" },
        { "path": "$HOME/.hermes" },
        { "path": "$HOME/.hermes/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/.openclaw" },
        { "path": "$HOME/.openclaw/**" },
        { "path": "$HOME/.openclaw-autoclaw" },
        { "path": "$HOME/.openclaw-autoclaw/**" },
        { "path": "$HOME/.hermes" },
        { "path": "$HOME/.hermes/**" }
      ]
    }
  ]
}